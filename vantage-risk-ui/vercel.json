{
  "rewrites": [{ "source": "/(.*)", "destination": "/" }],
  "env": {
    "VITE_API_URL": {
      "description": "FastAPI backend URL (Railway/Render)",
      "required": true
    }
  },
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite"
}
